[Unit]
Description=Graphic Share Platform FastAPI
After=network.target

[Service]
WorkingDirectory=/www/platform
EnvironmentFile=/www/platform/.env
ExecStart=/www/platform/.venv/bin/python -m uvicorn backend.main:app --host 127.0.0.1 --port 8001
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
