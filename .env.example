# 复制为 .env 即可生效。所有项均有默认值，演示场景无需配置。
APP_NAME=Graphic Share Platform
SECRET_KEY=please-change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SQLite（默认）/ MySQL：mysql+pymysql://user:pwd@host:3306/db
DATABASE_URL=sqlite:///./graphic_share_platform.db

UPLOAD_DIR=uploads
LOG_DIR=logs
CREATE_DEMO_DATA=true
DEBUG=true

# CORS：* 表示放开，生产请填写白名单，逗号分隔
CORS_ORIGINS=*
